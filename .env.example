# TwinOps AI — copy to .env (never commit .env; it is gitignored)

# --- web (Next.js, must be prefixed NEXT_PUBLIC_ to reach the browser) ---
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- app ---
TWINOPS_ENV=local
TWINOPS_DEBUG=true
# TWINOPS_CORS_ORIGINS='["http://localhost:3000"]'

# --- simulation (deterministic runs; shown in Settings) ---
TWINOPS_SIM_SEED=42

# --- infrastructure (docker compose defaults) ---
# DATABASE_URL=postgresql+asyncpg://twinops:twinops@localhost:5432/twinops
# VALKEY_URL=redis://localhost:6379/0
# OLLAMA_BASE_URL=http://localhost:11434

# --- LLM providers (ALL optional — the app boots with any ≥1; zero keys = Ollama-only) ---
# GOOGLE_API_KEY=            # Gemini free tier (AI Studio, no card)
# ANTHROPIC_API_KEY=         # optional, paid — activates the Claude adapter
# OPENAI_API_KEY=            # optional, paid — activates the OpenAI adapter
